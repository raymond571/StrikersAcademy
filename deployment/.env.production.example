# ─────────────────────────────────────────────────────────────
# StrikersAcademy — Production Environment Variables
# Copy to /var/www/strickersacademy/server/.env and fill in values
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000
HOST=127.0.0.1

# ── Domain & URLs ─────────────────────────────────────────────
DOMAIN=strickersacademy.in
CLIENT_URL=https://strickersacademy.in

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql://strikers_user:CHANGE_ME_PASSWORD@127.0.0.1:5432/strikersacademy?schema=public

# ── Auth / JWT ────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING
COOKIE_SECRET=CHANGE_ME_RANDOM_64_CHAR_STRING

# ── Razorpay (UPI Payments) ──────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=CHANGE_ME_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ── SSL (leave blank when using Nginx + Cloudflare) ──────────
# SSL_KEY_PATH=
# SSL_CERT_PATH=

# ── Cloudflare (optional — for API integrations) ─────────────
# CLOUDFLARE_ZONE_ID=
# CLOUDFLARE_API_TOKEN=
