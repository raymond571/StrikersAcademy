# ============================================================
# StrikersAcademy — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database (SQLite via Prisma) ──────────────────────────────
# Relative path from server/prisma/
DATABASE_URL="file:./dev.db"

# ── JWT Auth ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Cookie ────────────────────────────────────────────────────
COOKIE_SECRET=your_cookie_secret_change_this_in_production

# ── CORS ──────────────────────────────────────────────────────
# Frontend URL (dev: http://localhost:5173, prod: https://strikersacademy.in)
CLIENT_URL=http://localhost:5173

# ── HTTPS / SSL ──────────────────────────────────────────────
# Set both to enable HTTPS on the Fastify server directly.
# If using Cloudflare proxy or a reverse proxy (Caddy/Nginx), leave blank —
# the proxy handles TLS termination and Fastify runs HTTP behind it.
#
# For direct HTTPS (e.g., self-signed dev cert or Let's Encrypt):
#   SSL_KEY_PATH=./certs/privkey.pem
#   SSL_CERT_PATH=./certs/fullchain.pem
SSL_KEY_PATH=
SSL_CERT_PATH=

# ── Razorpay (UPI Payments) ───────────────────────────────────
# Get keys from https://dashboard.razorpay.com
# Use test keys for development, live keys for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Frontend (Vite exposes VITE_ prefix vars to client) ───────
VITE_API_URL=http://localhost:3000
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
VITE_APP_NAME=StrikersAcademy
